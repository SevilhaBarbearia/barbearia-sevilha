# Supabase - use as chaves públicas no frontend. Nunca exponha a service role key.
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anonima

# URL pública da aplicação, usada no callback OAuth
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Opcional: apenas em rotas server-side extremamente controladas.
# Não use no cliente e não exponha em logs.
SUPABASE_SERVICE_ROLE_KEY=
